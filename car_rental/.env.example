# ╔══════════════════════════════════════════════════════════╗
# ║   AutoLux — Variables d'environnement                   ║
# ║   Copiez ce fichier en .env et remplissez les valeurs   ║
# ╚══════════════════════════════════════════════════════════╝

# ── Environnement ──────────────────────────────────────────
# "development" pour local, "production" pour serveur public
DJANGO_ENV=production

# ── Clé secrète Django ─────────────────────────────────────
# Générez-en une avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=REMPLACEZ-PAR-UNE-VRAIE-CLE-SECRETE-LONGUE-ET-ALEATOIRE

# ── Domaines autorisés ─────────────────────────────────────
# Séparez par des virgules. Incluez votre domaine sans https://
ALLOWED_HOSTS=votre-domaine.com,www.votre-domaine.com

# ── Base de données PostgreSQL (optionnel) ─────────────────
# Laissez vide pour utiliser SQLite
DB_NAME=autolux_db
DB_USER=autolux_user
DB_PASSWORD=mot_de_passe_fort
DB_HOST=localhost
DB_PORT=5432

# ── Email SMTP (optionnel) ─────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=votre@email.com
EMAIL_HOST_PASSWORD=votre_mot_de_passe_app
DEFAULT_FROM_EMAIL=AutoLux <contact@autolux.tn>
